# Tony's Territory CRM — environment template
# Copy to .env and fill in values for local development.

# Server port (default 5000 — must match deployment proxy)
PORT=5000

# Node environment
NODE_ENV=development

# OSRM routing endpoint (defaults to public OSRM if unset)
# OSRM_BASE_URL=https://router.project-osrm.org

# Optional: override SQLite DB path (defaults to ./data.db)
# DATABASE_URL=./data.db
